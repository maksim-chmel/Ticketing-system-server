# Optional for `docker compose` — compose.yaml already ships demo defaults.
# Copy to `.env` only when you need to override secrets or connect from the host.

DefaultConnection=Host=localhost;Port=5433;Database=feedbackdb;Username=postgres;Password=postgres
JWT_SECRET_KEY=your-secret-key-minimum-32-chars
JWT_ISSUER=adminpanel
JWT_AUDIENCE=frontadminpanel
JWT_EXPIRES_IN_MINUTES=60
CORS_ORIGIN=http://localhost:3000
SEQ_URL=http://localhost:5341
REDIS_CONNECTION_STRING=redis:6379
API_KEY=dev-demo-api-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourStrongAdminPassword123!
MIGRATE_ON_STARTUP=true
